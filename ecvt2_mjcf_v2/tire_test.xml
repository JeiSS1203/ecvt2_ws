<mujoco model="SoftCylinder_Tire">
  <compiler angle="degree" meshdir="meshes/modified"/>

  <option solver="Newton" tolerance="1e-6" timestep="0.002" integrator="implicit"/>
  <size memory="200M"/>

  <asset>
    <mesh name="FLW" file="FLW.STL" />
  </asset>

  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <map stiffness="400" shadowscale="0.5" fogstart="1" fogend="20" zfar="40"/>
  </visual>

  <worldbody>
    <light name="main_light" pos="0 0 2.0" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" directional="true"/>

    <!-- 바닥 -->
    <geom name="ground" type="plane" size="0 0 1" pos="0 0 0"
          rgba="0.2 0.3 0.4 1"
          condim="3"
          friction="1.0 0.04 0.004"
          solref="0.002 1.0"
          solimp="0.9 0.95 0.005 0.5 2"/>

    <!-- ================= 기존 소프트 타이어 ================= -->
    <body pos="0 0 0.65" euler="10 0 0" name="soft_tire_body">
      <!-- <freejoint/> -->
      <geom type="sphere" size="0.1" contype="0" conaffinity="0" group="4"/>

      <flexcomp name="softbox" type="cylinder"
                count="5 5 5"
                spacing="0.3329125 0.3329125 0.115"
                radius="0.01" dim="3"
                euler="0 90 0"
                mass="436.42578487557">
        <contact internal="false" selfcollide="none"/>
        <edge equality="true" solref="0.01 1.5" solimp="0.9 0.95 0.001"/>
      </flexcomp>
    </body>

    <!-- ================= 비교용 강체 타이어 ================= -->
    <body name="ref_cylinder_body" pos="1.5 0 0.65" euler="0 90 0">
      <freejoint/>
      <geom name="tire_size_reference"
            type="mesh"
            mesh="FLW"
            rgba="0.7 0.7 0.7 1"
            condim="3" />
    </body> 

  </worldbody>
</mujoco>
